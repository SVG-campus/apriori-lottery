    "# ============================================================\n",
    "# CELL 2: SETUP + DATA INGESTION + FEATURE ENGINEERING\n",
    "# ============================================================\n",
    "import os, io, warnings, requests\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "from scipy.stats import skew, kurtosis\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "try:\n",
    "    from google.colab import userdata\n",
    "    HF_TOKEN = userdata.get('HF_ACCESS_TOKEN') or ''\n",
    "except:\n",
    "    HF_TOKEN = ''\n",
    "print(f'\u2705 Device: {device}')\n",
    "\n",
    "PB_URL = 'https://data.ny.gov/api/views/d6yy-54nr/rows.csv?accessType=DOWNLOAD'\n",
    "MM_URL = 'https://data.ny.gov/api/views/5xaw-6ayf/rows.csv?accessType=DOWNLOAD'\n",
    "\n",
    "def load_powerball():\n",
    "    print('\ud83c\udf10 Fetching Powerball...')\n",
    "    df = pd.read_csv(io.StringIO(requests.get(PB_URL, timeout=60).text))\n",
    "    df.columns = [c.strip() for c in df.columns]\n",
    "    df['draw_date'] = pd.to_datetime(df['Draw Date'], errors='coerce')\n",
    "    def parse(s):\n",
    "        try:\n",
    "            p = [int(x) for x in str(s).strip().split()]\n",
    "            return (p + [np.nan]*6)[:6]\n",
    "        except: return [np.nan]*6\n",
    "    df[['n1','n2','n3','n4','n5','pb']] = pd.DataFrame(\n",
    "        df['Winning Numbers'].apply(parse).tolist(), index=df.index)\n",
    "    df['multiplier'] = pd.to_numeric(df.get('Multiplier', pd.Series(np.nan, index=df.index)), errors='coerce')\n",
    "    df = df.dropna(subset=['draw_date','n1','n2','n3','n4','n5','pb'])\n",
    "    df = df.sort_values('draw_date').reset_index(drop=True)\n",
    "    df[['n1','n2','n3','n4','n5','pb']] = df[['n1','n2','n3','n4','n5','pb']].astype(int)\n",
    "    print(f'\u2705 Powerball: {len(df):,} draws [{df.draw_date.min().date()} \u2192 {df.draw_date.max().date()}]')\n",
    "    last = df.iloc[-1]\n",
    "    print(f'   Latest: {last.draw_date.date()} | {last.n1}-{last.n2}-{last.n3}-{last.n4}-{last.n5}  PB:{last.pb}')\n",
    "    return df\n",
    "\n",
    "def load_megamillions():\n",
    "    print('\ud83c\udf10 Fetching Mega Millions...')\n",
    "    df = pd.read_csv(io.StringIO(requests.get(MM_URL, timeout=60).text))\n",
    "    df.columns = [c.strip() for c in df.columns]\n",
    "    df['draw_date'] = pd.to_datetime(df['Draw Date'], errors='coerce')\n",
    "    def parse(s):\n",
    "        try:\n",
    "            p = [int(x) for x in str(s).strip().split()]\n",
    "            return (p + [np.nan]*5)[:5]\n",
    "        except: return [np.nan]*5\n",
    "    df[['n1','n2','n3','n4','n5']] = pd.DataFrame(\n",
    "        df['Winning Numbers'].apply(parse).tolist(), index=df.index)\n",
    "    mb_col = next((c for c in df.columns if 'mega' in c.lower() and 'ball' in c.lower()), None)\n",
    "    df['mb'] = pd.to_numeric(df[mb_col], errors='coerce') if mb_col else np.nan\n",
    "    df = df.dropna(subset=['draw_date','n1','n2','n3','n4','n5','mb'])\n",
    "    df = df.sort_values('draw_date').reset_index(drop=True)\n",
    "    df[['n1','n2','n3','n4','n5','mb']] = df[['n1','n2','n3','n4','n5','mb']].astype(int)\n",
    "    print(f'\u2705 Mega Millions: {len(df):,} draws [{df.draw_date.min().date()} \u2192 {df.draw_date.max().date()}]')\n",
    "    last = df.iloc[-1]\n",
    "    print(f'   Latest: {last.draw_date.date()} | {last.n1}-{last.n2}-{last.n3}-{last.n4}-{last.n5}  MB:{last.mb}')\n",
    "    return df\n",
    "\n",
    "pb_df = load_powerball()\n",
    "mm_df = load_megamillions()\n",
    "\n",
    "# ── Feature Engineering ────────────────────────────────────\n",
    "def hurst_proxy(series, min_len=20):\n",
    "    s = series.dropna()\n",
    "    if len(s) < min_len: return 0.5\n",
    "    ac = float(pd.Series(s.values).autocorr(lag=1))\n",
    "    return float(np.clip(0.5 + 0.5 * (ac if not np.isnan(ac) else 0), 0, 1))\n",
    "\n",
    "def engineer_features(df, spec_col):\n",
    "    df = df.copy().sort_values('draw_date').reset_index(drop=True)\n",
    "    nc = ['n1','n2','n3','n4','n5']\n",
    "    nums = df[nc].values\n",
    "    df['day_of_week'] = df['draw_date'].dt.dayofweek\n",
    "    df['month']       = df['draw_date'].dt.month\n",
    "    df['year']        = df['draw_date'].dt.year\n",
    "    df['draw_idx']    = np.arange(len(df))\n",
    "    df['draw_sum']    = nums.sum(1)\n",
    "    df['draw_mean']   = nums.mean(1)\n",
    "    df['draw_std']    = nums.std(1)\n",
    "    df['draw_range']  = nums.max(1) - nums.min(1)\n",
    "    df['draw_skew']   = [float(skew(r))     for r in nums]\n",
    "    df['draw_kurt']   = [float(kurtosis(r)) for r in nums]\n",
    "    df['n_odd']       = (nums % 2).sum(1)\n",
    "    df['n_low']       = (nums <= (nums.max(1, keepdims=True) / 2)).sum(1)\n",
    "    for col in nc:\n",
    "        for m in [3, 5, 7, 10]:\n",
    "            df[f'{col}_mod{m}'] = df[col] % m\n",
    "        df[f'{col}_parity'] = df[col] % 2\n",
    "        for lag in [1, 2, 3]:\n",
    "            df[f'{col}_lag{lag}'] = df[col].shift(lag)\n",
    "        df[f'{col}_delta']  = df[col].diff()\n",
    "        df[f'{col}_delta2'] = df[col].diff().diff()\n",
    "    for i, c1 in enumerate(nc):\n",
    "        for c2 in nc[i+1:]:\n",
    "            df[f'{c1}_{c2}_sum']  = df[c1] + df[c2]\n",
    "            df[f'{c1}_{c2}_diff'] = (df[c1] - df[c2]).abs()\n",
    "            df[f'{c1}_{c2}_prod'] = df[c1] * df[c2]\n",
    "    for lag in [1, 2, 3]:\n",
    "        df[f'{spec_col}_lag{lag}'] = df[spec_col].shift(lag)\n",
    "    df[f'{spec_col}_delta'] = df[spec_col].diff()\n",
    "    w = min(30, len(df) // 4)\n",
    "    for col in ['draw_sum', 'draw_std', 'draw_range']:\n",
    "        df[f'{col}_roll_mean'] = df[col].rolling(w, min_periods=max(5, w//2)).mean().fillna(df[col].mean())\n",
    "        df[f'{col}_roll_std']  = df[col].rolling(w, min_periods=max(5, w//2)).std().fillna(0)\n",
    "    df['sum_hurst'] = (df['draw_sum']\n",
    "                       .rolling(w, min_periods=max(5, w//2))\n",
    "                       .apply(hurst_proxy, raw=False)\n",
    "                       .fillna(0.5))\n",
    "    df = df.fillna(0)\n",
    "    return df\n",
    "\n",
    "pb_feat = engineer_features(pb_df, spec_col='pb')\n",
    "mm_feat = engineer_features(mm_df, spec_col='mb')\n",
    "print(f'\n\ud83d\udcca pb_feat: {pb_feat.shape}  |  mm_feat: {mm_feat.shape}')"
   ]
  },
