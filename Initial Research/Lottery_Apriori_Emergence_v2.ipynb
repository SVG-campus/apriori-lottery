    "# ============================================================\n",
    "# CELL 4: XGBOOST PREDICTORS + MONTE CARLO SIMULATION\n",
    "# ============================================================\n",
    "import xgboost as xgb\n",
    "from sklearn.model_selection import cross_val_score\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from collections import Counter\n",
    "import numpy as np\n",
    "\n",
    "_xgb_major = int(xgb.__version__.split('.')[0])\n",
    "def xgb_gpu_params():\n",
    "    return {'tree_method': 'hist', 'device': 'cuda'} if _xgb_major >= 2 \\\n",
    "           else {'tree_method': 'gpu_hist'}\n",
    "\n",
    "DROP = {'draw_date','Draw Date','Winning Numbers','Mega Ball',\n",
    "        'Multiplier','multiplier','megaplier'}\n",
    "BALL_COLS = {'n1','n2','n3','n4','n5','pb','mb'}\n",
    "\n",
    "def train_xgb(feat_df, game='Game'):\n",
    "    feat_cols = [c for c in feat_df.columns\n",
    "                 if c not in DROP and feat_df[c].dtype != object]\n",
    "    results = {}\n",
    "    for target in ['n1','n2','n3','n4','n5']:\n",
    "        if target not in feat_df.columns: continue\n",
    "        X = feat_df[[c for c in feat_cols\n",
    "                     if c not in BALL_COLS or c == target]].drop(\n",
    "            columns=[target], errors='ignore')\n",
    "        y = feat_df[target].values\n",
    "        model = xgb.XGBRegressor(\n",
    "            n_estimators=500, max_depth=5, learning_rate=0.04,\n",
    "            subsample=0.8, colsample_bytree=0.8,\n",
    "            min_child_weight=3, gamma=0.1,\n",
    "            random_state=42, n_jobs=-1, verbosity=0,\n",
    "            **xgb_gpu_params())\n",
    "        cv = cross_val_score(model, X, y, cv=5, scoring='neg_mean_absolute_error')\n",
    "        model.fit(X, y)\n",
    "        results[target] = {'model': model, 'mae': -cv.mean(), 'std': cv.std()}\n",
    "        print(f'  {game} {target}: MAE={-cv.mean():.3f} \u00b1 {cv.std():.3f}')\n",
    "    return results\n",
    "\n",
    "def train_special_xgb(feat_df, spec_col, max_num, game='Game'):\n",
    "    feat_cols = [c for c in feat_df.columns\n",
    "                 if c not in DROP and feat_df[c].dtype != object\n",
    "                 and c not in BALL_COLS]\n",
    "    X = feat_df[feat_cols]\n",
    "    y = feat_df[spec_col].values\n",
    "    le = LabelEncoder()\n",
    "    yenc = le.fit_transform(y)\n",
    "    model = xgb.XGBClassifier(\n",
    "        n_estimators=400, max_depth=4, learning_rate=0.05,\n",
    "        subsample=0.8, colsample_bytree=0.8,\n",
    "        use_label_encoder=False, eval_metric='mlogloss',\n",
    "        random_state=42, n_jobs=-1, verbosity=0,\n",
    "        **xgb_gpu_params())\n",
    "    model.fit(X, yenc)\n",
    "    probs = model.predict_proba(X.iloc[[-1]])[0]\n",
    "    top3_idx = np.argsort(probs)[::-1][:3]\n",
    "    top3     = [int(le.inverse_transform([i])[0]) for i in top3_idx]\n",
    "    print(f'  {game} {spec_col} top-3 prediction: {top3}')\n",
    "    return top3, model\n",
    "\n",
    "def run_mc(df, white_max, spec_max, spec_col, n_sims=200_000, game='Game'):\n",
    "    print(f'\n\ud83c\udfb2 Running {n_sims:,} MC simulations for {game}...')\n",
    "    nc = ['n1','n2','n3','n4','n5']\n",
    "    white_counts = Counter()\n",
    "    spec_counts  = Counter()\n",
    "    for _, row in df.iterrows():\n",
    "        for c in nc: white_counts[int(row[c])] += 1\n",
    "        spec_counts[int(row[spec_col])] += 1\n",
    "    whites = np.array([white_counts.get(n, 1) for n in range(1, white_max+1)], dtype=float)\n",
    "    whites /= whites.sum()\n",
    "    specs  = np.array([spec_counts.get(n, 1) for n in range(1, spec_max+1)], dtype=float)\n",
    "    specs  /= specs.sum()\n",
    "    rng = np.random.default_rng(42)\n",
    "    sim_white = Counter()\n",
    "    sim_spec  = Counter()\n",
    "    for _ in range(n_sims):\n",
    "        drawn = rng.choice(white_max, size=5, replace=False, p=whites) + 1\n",
    "        sp    = rng.choice(spec_max,  size=1, p=specs)[0] + 1\n",
    "        sim_white.update(drawn.tolist())\n",
    "        sim_spec[int(sp)] += 1\n",
    "    top_whites   = [n for n, _ in sim_white.most_common(10)]\n",
    "    top_specials = [n for n, _ in sim_spec.most_common(5)]\n",
    "    print(f'\n\ud83d\udcca Top 10 White Balls ({game}):')\n",
    "    total_w = sum(sim_white.values())\n",
    "    for n, c in sim_white.most_common(10): print(f'   {n:2d} \u2192 {c/total_w*100:.2f}%')\n",
    "    print(f'\n\ud83d\udcca Top 5 Special Balls ({game}):')\n",
    "    total_s = sum(sim_spec.values())\n",
    "    for n, c in sim_spec.most_common(5): print(f'   {n:2d} \u2192 {c/total_s*100:.2f}%')\n",
    "    return sim_white, sim_spec, top_whites, top_specials\n",
    "\n",
    "print('=== POWERBALL XGBoost ===')\n",
    "pb_xgb = train_xgb(pb_feat, game='Powerball')\n",
    "print('\n--- Powerball special ball predictor ---')\n",
    "pb_sc_pred, pb_sc_model = train_special_xgb(pb_feat, 'pb', 26, game='Powerball')\n",
    "print('\n=== MEGA MILLIONS XGBoost ===')\n",
    "mm_xgb = train_xgb(mm_feat, game='MegaMillions')\n",
    "print('\n--- MegaMillions special ball predictor ---')\n",
    "mm_sc_pred, mm_sc_model = train_special_xgb(mm_feat, 'mb', 25, game='MegaMillions')\n",
    "print('\n' + '='*60)\n",
    "pb_mc = run_mc(pb_df, white_max=69, spec_max=26, spec_col='pb', game='Powerball')\n",
    "mm_mc = run_mc(mm_df, white_max=70, spec_max=25, spec_col='mb', game='MegaMillions')\n",
    "pb_mc_whites, pb_mc_specials = pb_mc[0], pb_mc[1]\n",
    "mm_mc_whites, mm_mc_specials = mm_mc[0], mm_mc[1]"
   ]
