    "# ============================================================\n",
    "# CELL 5: FUSION + WALK-FORWARD VALIDATION + FINAL TICKET\n",
    "# ============================================================\n",
    "from collections import Counter\n",
    "import numpy as np, pandas as pd\n",
    "\n",
    "def fuse(mc_freq, xgb_results, rules_df, feat_df,\n",
    "         n_picks=5, max_num=69, game='Game'):\n",
    "    print(f\"\\n{'='*52}\")\n",
    "    print(f'  {game} FUSION: MC + XGBoost + Apriori')\n",
    "    print(f\"{'='*52}\")\n",
    "    total_mc  = sum(mc_freq.values()) or 1\n",
    "    mc_scores = {n: mc_freq.get(n, 0) / total_mc for n in range(1, max_num+1)}\n",
    "    xgb_scores = Counter()\n",
    "    if feat_df is not None:\n",
    "        drop = {'draw_date','Draw Date','Winning Numbers','Mega Ball',\n",
    "                'Multiplier','multiplier','megaplier'}\n",
    "        ball = {'n1','n2','n3','n4','n5','pb','mb'}\n",
    "        for target, res in xgb_results.items():\n",
    "            model = res['model']\n",
    "            try:\n",
    "                fc = list(model.feature_names_in_)\n",
    "                lr = feat_df[fc].iloc[[-1]]\n",
    "                pred = int(np.clip(round(float(model.predict(lr)[0])), 1, max_num))\n",
    "                for off in [-1, 0, 1]:\n",
    "                    n = pred + off\n",
    "                    if 1 <= n <= max_num: xgb_scores[n] += (2 if off == 0 else 1)\n",
    "            except Exception as e:\n",
    "                print(f'  \u26a0\ufe0f  XGBoost skip {target}: {e}')\n",
    "    xgb_max = max(xgb_scores.values(), default=1) or 1\n",
    "    apriori_scores = Counter()\n",
    "    if rules_df is not None and isinstance(rules_df, pd.DataFrame) and not rules_df.empty:\n",
    "        for _, row in rules_df.head(50).iterrows():\n",
    "            for item in row['consequents']:\n",
    "                try:\n",
    "                    num = int(str(item).split('_')[0][1:])\n",
    "                    if 1 <= num <= max_num: apriori_scores[num] += float(row['lift'])\n",
    "                except: pass\n",
    "    apriori_max = max(apriori_scores.values(), default=1) or 1\n",
    "    final = {n: (0.50 * mc_scores[n]\n",
    "                 + 0.30 * xgb_scores.get(n, 0) / xgb_max\n",
    "                 + 0.20 * apriori_scores.get(n, 0) / apriori_max)\n",
    "             for n in range(1, max_num+1)}\n",
    "    picks = sorted(sorted(final, key=final.get, reverse=True)[:n_picks])\n",
    "    top_score = max(final.values())\n",
    "    conf = {n: round(final[n] / top_score * 100, 1) for n in picks}\n",
    "    print(f'  \ud83c\udfaf Fused picks : {picks}')\n",
    "    print(f'  \ud83d\udcc8 Confidence  : {conf}  (relative %)')\n",
    "    print(f'  (MC 50% | XGBoost 30% | Apriori 20%)')\n",
    "    return picks, final\n",
    "\n",
    "def fuse_special(mc_spec_freq, xgb_pred, max_num, game='Game'):\n",
    "    total = sum(mc_spec_freq.values()) or 1\n",
    "    mc_s  = {n: mc_spec_freq.get(n, 0) / total for n in range(1, max_num+1)}\n",
    "    xgb_s = Counter()\n",
    "    for rank, n in enumerate(xgb_pred[:3]): xgb_s[n] += (3 - rank)\n",
    "    xgb_max = max(xgb_s.values(), default=1) or 1\n",
    "    final = {n: 0.60 * mc_s[n] + 0.40 * xgb_s.get(n, 0) / xgb_max for n in range(1, max_num+1)}\n",
    "    best = max(final, key=final.get)\n",
    "    print(f'  \ud83c\udfb0 {game} Special ball: {best}  '\n",
    "          f'(MC top: {list(mc_spec_freq.most_common(1)[0])}, XGB top: {xgb_pred[0]})')\n",
    "    return best\n",
    "\n",
    "def walk_forward(df, feat_df, white_max, spec_col, n_windows=10, window_size=100, game='Game'):\n",
    "    print(f'\n=== {game} Walk-Forward Validation ===')\n",
    "    nc = ['n1','n2','n3','n4','n5']\n",
    "    n  = len(df)\n",
    "    hits_list = []\n",
    "    random_baseline = 5 * 5 / white_max\n",
    "    for w in range(n_windows):\n",
    "        end   = n - (n_windows - w) * (window_size // n_windows)\n",
    "        start = max(0, end - window_size)\n",
    "        test_rows = df.iloc[end:end + window_size // n_windows]\n",
    "        if len(test_rows) == 0: continue\n",
    "        white_counts = Counter()\n",
    "        for _, row in df.iloc[start:end].iterrows():\n",
    "            for c in nc: white_counts[int(row[c])] += 1\n",
    "        pred_ticket = sorted([n for n, _ in white_counts.most_common(5)])\n",
    "        hit_counts = []\n",
    "        for _, row in test_rows.iterrows():\n",
    "            actual = {int(row[c]) for c in nc}\n",
    "            hit_counts.append(len(set(pred_ticket) & actual))\n",
    "        avg_hits = np.mean(hit_counts)\n",
    "        hits_list.append(avg_hits)\n",
    "        print(f'   Window {w+1:2d}: predicted {pred_ticket} \u2192 avg hits/draw: {avg_hits:.2f}')\n",
    "    mean_hits = np.mean(hits_list)\n",
    "    edge_pct  = (mean_hits / random_baseline - 1) * 100 if random_baseline > 0 else 0\n",
    "    print(f'\n\u2705 {game} Walk-Forward Mean Hits/Draw: {mean_hits:.3f}/5')\n",
    "    print(f'   Random baseline: {random_baseline:.3f}/5')\n",
    "    print(f'   Edge over random: {edge_pct:+.1f}%')\n",
    "    return mean_hits, random_baseline\n",
    "\n",
    "pb_ticket, pb_final = fuse(pb_mc_whites, pb_xgb, pb_rules, pb_feat, n_picks=5, max_num=69, game='Powerball')\n",
    "pb_ball = fuse_special(pb_mc_specials, pb_sc_pred, max_num=26, game='Powerball')\n",
    "mm_ticket, mm_final = fuse(mm_mc_whites, mm_xgb, mm_rules, mm_feat, n_picks=5, max_num=70, game='MegaMillions')\n",
    "mm_ball = fuse_special(mm_mc_specials, mm_sc_pred, max_num=25, game='MegaMillions')\n",
    "pb_hits, pb_base = walk_forward(pb_df, pb_feat, 69, 'pb', game='Powerball')\n",
    "mm_hits, mm_base = walk_forward(mm_df, mm_feat, 70, 'mb', game='MegaMillions')\n",
    "print(f\"\\n{'='*62}\")\n",
    "print(f'  \ud83c\udfc6 POWERBALL TICKET    : {pb_ticket}  PB: {pb_ball}')\n",
    "print(f'  \ud83c\udfc6 MEGA MILLIONS TICKET: {mm_ticket}  MB: {mm_ball}')\n",
    "print(f\"{'='*62}\")"
   ]
