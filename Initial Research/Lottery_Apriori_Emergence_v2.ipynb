    "# ============================================================\n",
    "# CELL 3: APRIORI RULES + O-INFO SYNERGY BEAM\n",
    "# ============================================================\n",
    "from mlxtend.frequent_patterns import apriori, association_rules\n",
    "from itertools import combinations\n",
    "import numpy as np, pandas as pd\n",
    "from tqdm import tqdm\n",
    "\n",
    "def run_apriori(feat_df, num_cols=['n1','n2','n3','n4','n5'], game='Game', min_support=0.03):\n",
    "    basket = pd.DataFrame()\n",
    "    for col in num_cols:\n",
    "        med = feat_df[col].median()\n",
    "        basket[f'{col}_hi'] = (feat_df[col] > med).astype(bool)\n",
    "        basket[f'{col}_lo'] = (feat_df[col] <= med).astype(bool)\n",
    "    try:\n",
    "        fi = apriori(basket, min_support=min_support, use_colnames=True, max_len=4)\n",
    "        if fi.empty: return fi, pd.DataFrame()\n",
    "        rules = association_rules(fi, metric='lift', min_threshold=1.0)\n",
    "        rules = rules.sort_values('lift', ascending=False)\n",
    "        print(f'\u2705 {game} Apriori: {len(fi)} itemsets, {len(rules)} rules')\n",
    "        return fi, rules\n",
    "    except Exception as e:\n",
    "        print(f'\u26a0\ufe0f {game} Apriori error: {e}')\n",
    "        return pd.DataFrame(), pd.DataFrame()\n",
    "\n",
    "def discretize(s, bins=10):\n",
    "    return pd.cut(s, bins=bins, labels=False, duplicates='drop').fillna(0).astype(int)\n",
    "\n",
    "def joint_entropy(*arrays):\n",
    "    stacked = np.stack(arrays, axis=1)\n",
    "    _, counts = np.unique(stacked, axis=0, return_counts=True)\n",
    "    p = counts / counts.sum()\n",
    "    return -np.sum(p * np.log2(p + 1e-12))\n",
    "\n",
    "def o_information(arrays):\n",
    "    n = len(arrays)\n",
    "    if n < 2: return 0.0\n",
    "    total_H  = joint_entropy(*arrays)\n",
    "    marginal = sum(joint_entropy(a) for a in arrays)\n",
    "    loo      = sum(joint_entropy(*[arrays[j] for j in range(n) if j != i]) for i in range(n))\n",
    "    return (n - 2) * total_H + marginal - loo\n",
    "\n",
    "def synergy_beam(df, feat_cols, max_order=4, min_synergy=-0.05, beam_width=30):\n",
    "    cols = [c for c in feat_cols if df[c].nunique() > 1]\n",
    "    disc = {c: discretize(df[c]).values for c in cols}\n",
    "    results, beam = [], [(c,) for c in cols]\n",
    "    for order in range(2, max_order + 1):\n",
    "        candidates, seen = [], set()\n",
    "        for seed in beam:\n",
    "            for ext in cols:\n",
    "                if ext in seed: continue\n",
    "                cand = tuple(sorted(seed + (ext,)))\n",
    "                if cand in seen: continue\n",
    "                seen.add(cand)\n",
    "                oi = o_information([disc[c] for c in cand])\n",
    "                candidates.append((cand, oi))\n",
    "        candidates.sort(key=lambda x: x[1])\n",
    "        emergent = [(c, oi) for c, oi in candidates if oi < min_synergy]\n",
    "        print(f'  Order {order}: {len(candidates)} candidates, {len(emergent)} synergistic')\n",
    "        for combo, oi in emergent[:3]:\n",
    "            print(f'    \U0001f300 {combo} \u2192 O-info={oi:.4f}')\n",
    "        for combo, oi in emergent:\n",
    "            results.append({'order': order, 'combo': combo, 'o_info': oi})\n",
    "        beam = [c for c, _ in candidates[:beam_width]]\n",
    "        if not beam: break\n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "oi_cols = lambda feat: [c for c in feat.columns\n",
    "                         if any(x in c for x in\n",
    "                                ['mod3','mod5','mod7','parity','delta',\n",
    "                                 'sum','mean','std','range','hurst'])]\n",
    "\n",
    "print('=== Powerball Apriori ===')\n",
    "pb_freq, pb_rules = run_apriori(pb_feat, game='Powerball')\n",
    "print('\n=== MegaMillions Apriori ===')\n",
    "mm_freq, mm_rules = run_apriori(mm_feat, game='MegaMillions')\n",
    "print('\n=== Powerball O-Info Synergy Beam ===')\n",
    "pb_synergy = synergy_beam(pb_feat, oi_cols(pb_feat))\n",
    "print('\n=== MegaMillions O-Info Synergy Beam ===')\n",
    "mm_synergy = synergy_beam(mm_feat, oi_cols(mm_feat))"
   ]
